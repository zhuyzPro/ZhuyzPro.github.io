<% const posts = published_posts(); %>
<section class="page-hero editorial-hero">
  <p class="eyebrow">Tea Journal</p>
  <h1><%= page.title %></h1>
  <p><%= page.description %></p>
</section>
<section class="section-block section-contained">
  <div class="post-list">
    <% posts.forEach((post) => { %>
      <%- partial('_partial/post-card', { post: post }) %>
    <% }); %>
  </div>
</section>
