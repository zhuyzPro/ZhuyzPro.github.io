<% const aromas = (site.data.aromas || []).filter((item) => item.status === 'published').sort((left, right) => Number(left.order || 99) - Number(right.order || 99)); %>
<% const majorAromas = aromas.filter((item) => item.major); %>
<% const otherAromas = aromas.filter((item) => !item.major); %>
<% const products = published_products(); %>
<section class="aroma-hero" aria-labelledby="aroma-title">
  <div class="aroma-hero-copy">
    <p class="eyebrow">Aroma Library</p>
    <h1 id="aroma-title"><%= page.title %></h1>
    <p><%= page.description %></p>
    <dl class="aroma-hero-stats" aria-label="香型资料概览">
      <div><dt>主流香型</dt><dd><%= majorAromas.length %></dd></div>
      <div><dt>当前茶品</dt><dd><%= products.length %></dd></div>
      <div><dt>其他收录</dt><dd><%= otherAromas.length %></dd></div>
    </dl>
  </div>
  <div class="aroma-hero-board" aria-label="凤凰单枞十大香型">
    <% majorAromas.forEach((aroma) => { %>
      <% const related = products.find((product) => product.taxonomy && product.taxonomy.aroma_id === aroma.id); %>
      <a class="aroma-hero-tile <%= related ? 'has-product' : '' %>" href="<%- url_for(`/aromas/#${aroma.id}`) %>" data-mark="<%= aroma.name.charAt(0) %>">
        <span><%= String(aroma.order).padStart(2, '0') %></span>
        <strong><%= aroma.name %></strong>
        <small><%= (aroma.tags || []).slice(0, 2).join(' · ') %></small>
      </a>
    <% }); %>
  </div>
</section>

<section class="aroma-reading-panel">
  <div class="aroma-reading-copy">
    <%- page.content %>
  </div>
  <aside class="aroma-reading-aside">
    <p class="eyebrow">Boundary</p>
    <h2>先识香，再看批次</h2>
    <p>香型只是第一层入口；具体茶品仍要回到品种/株系、焙火、汤感、价格状态和冲泡参数一起判断。</p>
    <a class="text-link" href="<%- url_for('/products/') %>">进入茶品图鉴<span aria-hidden="true">→</span></a>
  </aside>
</section>

<section class="aroma-detail-section section-contained">
  <header class="section-heading">
    <div>
      <p class="eyebrow">Aroma Notes</p>
      <h2>十大香型说明</h2>
      <p>每个香型先作为感官坐标，再回到具体批次页看实际表现。</p>
    </div>
  </header>
  <div class="aroma-detail-grid">
  <% majorAromas.forEach((aroma, index) => { %>
    <% const related = products.find((product) => product.taxonomy && product.taxonomy.aroma_id === aroma.id); %>
    <article class="aroma-detail" id="<%= aroma.id %>">
      <span class="aroma-index"><%= String(index + 1).padStart(2, '0') %></span>
      <p class="eyebrow">十大香型</p>
      <h2><%= aroma.name %></h2>
      <% if (aroma.aliases && aroma.aliases.length) { %><p class="aroma-alias">常见异名：<%= aroma.aliases.join('、') %></p><% } %>
      <p><%= aroma.profile %></p>
      <ul class="tag-list">
        <% (aroma.tags || []).forEach((tag) => { %><li><%= tag %></li><% }); %>
      </ul>
      <% if (related) { %>
        <a class="text-link" href="<%- url_for(related.path) %>">查看关联茶品<span aria-hidden="true">→</span></a>
      <% } %>
    </article>
  <% }); %>
  </div>
</section>

<% if (otherAromas.length) { %>
  <section class="other-aroma-section section-contained">
    <header class="section-heading">
      <div>
        <p class="eyebrow">Other Notes</p>
        <h2>其他常见香型</h2>
        <p>不强行并入十大香型，用于承接已有茶品和后续扩展。</p>
      </div>
    </header>
    <div class="other-aroma-grid">
      <% otherAromas.forEach((aroma) => { %>
        <% const related = products.find((product) => product.taxonomy && product.taxonomy.aroma_id === aroma.id); %>
        <article class="other-aroma-card" id="<%= aroma.id %>">
          <p class="eyebrow">其他常见香型</p>
          <h3><%= aroma.name %></h3>
          <p><%= aroma.profile %></p>
          <% if (related) { %><a class="text-link" href="<%- url_for(related.path) %>">查看关联茶品<span aria-hidden="true">→</span></a><% } %>
        </article>
      <% }); %>
    </div>
</section>
<% } %>

<section class="consult-band section-contained">
  <div>
    <p class="eyebrow">Taste Guidance</p>
    <h2>香型相近，实际滋味仍会因批次而变化</h2>
    <p>选择时可以同时说明常喝的茶、偏好的香气、能否接受焙火感，以及日常使用的器具。</p>
  </div>
  <a class="button light" href="<%- url_for('/contact/?topic=aroma') %>">咨询香型选择</a>
</section>
