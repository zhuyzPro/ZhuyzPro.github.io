<% const home = theme.home || {}; %>
<% const hero = home.hero || {}; %>
<% const opening = home.opening || {}; %>
<% const sections = home.sections || {}; %>
<% const sidebar = home.sidebar || {}; %>
<% const products = published_products(); %>
<% const posts = published_posts(); %>
<% const aromas = (site.data.aromas || []).filter((item) => item.status === 'published'); %>
<% const process = site.data.process || []; %>
<% const brewingQuick = (site.data.brewing && site.data.brewing.quick) || []; %>
<div class="home-page">
  <div class="home-notice" aria-label="茶事更新">
    <div>
      <span><%= home.notice.label %></span>
      <p><%= home.notice.text %></p>
      <a href="<%- url_for(home.notice.link_url) %>"><%= home.notice.link_label %><span aria-hidden="true">→</span></a>
    </div>
  </div>

  <div class="home-opening">
    <section class="home-hero" aria-labelledby="home-title">
      <img class="home-hero-image" src="<%- url_for(hero.image) %>" alt="凤凰单枞茶席与茶汤" fetchpriority="high" />
      <div class="home-hero-shade" aria-hidden="true"></div>
      <div class="home-hero-inner">
        <div class="home-hero-copy">
          <p class="eyebrow"><%= hero.eyebrow %></p>
          <h1 id="home-title"><%= hero.title %></h1>
          <p class="home-hero-lead"><%= hero.copy %></p>
          <div class="hero-actions">
            <% (hero.ctas || []).forEach((cta) => { %>
              <a class="button <%= cta.style === 'secondary' ? 'secondary' : 'primary' %>" href="<%- url_for(cta.url) %>"><%= cta.label %></a>
            <% }); %>
          </div>
          <ul class="hero-notes" aria-label="站点内容重点">
            <% (hero.notes || []).forEach((note) => { %>
              <li><%= note %></li>
            <% }); %>
          </ul>
        </div>
      </div>
    </section>

    <aside class="home-opening-aside" aria-label="首页重点入口">
      <a class="opening-card opening-aroma-card" href="<%- url_for('/aromas/') %>">
        <div>
          <p class="eyebrow"><%= opening.aroma_eyebrow %></p>
          <h2><%= opening.aroma_title %></h2>
          <p><%= opening.aroma_copy %></p>
        </div>
        <ul aria-label="已整理香型">
          <% aromas.slice(0, 3).forEach((aroma) => { %>
            <li><span><%= aroma.name %></span><small><%= (aroma.tags || []).slice(0, 2).join(' · ') %></small></li>
          <% }); %>
        </ul>
        <strong><%= opening.aroma_link %><span aria-hidden="true">→</span></strong>
      </a>

      <a class="opening-card opening-season-card" href="<%- url_for('/products/') %>">
        <div>
          <p class="eyebrow"><%= opening.season_eyebrow %></p>
          <h2><%= opening.season_title %></h2>
          <p><%= opening.season_copy %></p>
        </div>
        <dl>
          <div><dt>展示批次</dt><dd><%= products.length %></dd></div>
          <div><dt>香型档案</dt><dd><%= aromas.length %></dd></div>
          <div><dt>采制环节</dt><dd><%= process.length %></dd></div>
        </dl>
        <strong><%= opening.season_link %><span aria-hidden="true">→</span></strong>
      </a>
    </aside>
  </div>

  <nav class="home-pathways" aria-label="站点主要内容">
    <% (home.pathways || []).forEach((item, index) => { %>
      <a href="<%- url_for(item.url) %>">
        <span class="pathway-number"><%= String(index + 1).padStart(2, '0') %></span>
        <span class="pathway-copy">
          <small><%= item.kicker %></small>
          <strong><%= item.title %></strong>
          <em><%= item.desc %></em>
        </span>
        <span class="pathway-arrow" aria-hidden="true">→</span>
      </a>
    <% }); %>
  </nav>

  <div class="home-content-shell">
    <div class="home-feed">
      <section class="section-block home-section home-products-section">
        <header class="section-heading">
          <div>
            <p class="eyebrow"><%= sections.products.eyebrow %></p>
            <h2><%= sections.products.title %></h2>
            <p><%= sections.products.copy %></p>
          </div>
          <a class="text-link" href="<%- url_for(sections.products.link_url) %>"><%= sections.products.link_label %><span aria-hidden="true">→</span></a>
        </header>
        <div class="home-product-grid">
          <% products.slice(0, 3).forEach((product) => { %>
            <%- partial('_partial/product-card', { product: product }) %>
          <% }); %>
        </div>
      </section>

      <section class="home-aroma-band">
        <div class="home-band-inner">
          <header class="section-heading section-heading-light">
            <div>
              <p class="eyebrow"><%= sections.aromas.eyebrow %></p>
              <h2><%= sections.aromas.title %></h2>
              <p><%= sections.aromas.copy %></p>
            </div>
            <a class="text-link" href="<%- url_for(sections.aromas.link_url) %>"><%= sections.aromas.link_label %><span aria-hidden="true">→</span></a>
          </header>
          <div class="aroma-preview-grid">
            <% aromas.slice(0, 3).forEach((aroma, index) => { %>
              <a class="aroma-preview" href="<%- url_for(`/aromas/#${aroma.id}`) %>">
                <span class="aroma-index"><%= String(index + 1).padStart(2, '0') %></span>
                <h3><%= aroma.name %></h3>
                <p><%= aroma.profile %></p>
                <span class="aroma-tags"><%= (aroma.tags || []).join(' · ') %></span>
              </a>
            <% }); %>
          </div>
        </div>
      </section>

      <section class="origin-feature">
        <figure>
          <img src="<%- url_for(sections.origin.image) %>" alt="凤凰山产地与茶园环境" loading="lazy" decoding="async" />
        </figure>
        <div class="origin-feature-copy">
          <p class="eyebrow"><%= sections.origin.eyebrow %></p>
          <h2><%= sections.origin.title %></h2>
          <p><%= sections.origin.copy %></p>
          <div class="origin-facts" aria-label="产地资料摘要">
            <div><small>行政产地</small><strong>潮州市凤凰镇</strong></div>
            <div><small>公开方式</small><strong>片区与批次分层</strong></div>
          </div>
          <a class="button outline" href="<%- url_for(sections.origin.link_url) %>"><%= sections.origin.link_label %></a>
        </div>
      </section>

      <section class="section-block home-section home-process-section" id="process">
        <header class="section-heading">
          <div>
            <p class="eyebrow"><%= sections.process.eyebrow %></p>
            <h2><%= sections.process.title %></h2>
            <p><%= sections.process.copy %></p>
          </div>
          <a class="text-link" href="<%- url_for(sections.process.link_url) %>"><%= sections.process.link_label %><span aria-hidden="true">→</span></a>
        </header>
        <ol class="home-process-grid">
          <% process.slice(0, 5).forEach((step, index) => { %>
            <li>
              <span><%= String(index + 1).padStart(2, '0') %></span>
              <div>
                <h3><%= step.name %></h3>
                <p><%= step.note %></p>
              </div>
            </li>
          <% }); %>
        </ol>
      </section>

      <section class="brewing-overview">
        <header>
          <p class="eyebrow"><%= sections.brewing.eyebrow %></p>
          <h2><%= sections.brewing.title %></h2>
          <p><%= sections.brewing.copy %></p>
          <a class="text-link" href="<%- url_for(sections.brewing.link_url) %>"><%= sections.brewing.link_label %><span aria-hidden="true">→</span></a>
        </header>
        <dl class="brewing-quick-grid">
          <% brewingQuick.forEach((item) => { %>
            <div>
              <dt><%= item.label %></dt>
              <dd><%= item.value %></dd>
              <p><%= item.note %></p>
            </div>
          <% }); %>
        </dl>
      </section>

      <section class="section-block home-section home-posts-section">
        <header class="section-heading">
          <div>
            <p class="eyebrow"><%= sections.posts.eyebrow %></p>
            <h2><%= sections.posts.title %></h2>
            <p><%= sections.posts.copy %></p>
          </div>
          <a class="text-link" href="<%- url_for(sections.posts.link_url) %>"><%= sections.posts.link_label %><span aria-hidden="true">→</span></a>
        </header>
        <div class="home-post-grid">
          <% posts.slice(0, 3).forEach((post) => { %>
            <%- partial('_partial/post-card', { post: post }) %>
          <% }); %>
        </div>
      </section>
    </div>

    <aside class="home-sidebar" aria-label="首页辅助信息">
      <section class="home-sidebar-card home-brand-note">
        <p class="eyebrow"><%= sidebar.brand_eyebrow %></p>
        <h2><%= sidebar.brand_title %></h2>
        <p><%= sidebar.brand_copy %></p>
        <div class="brand-note-signature" aria-hidden="true">
          <span>凤凰山</span>
          <strong>单枞</strong>
        </div>
      </section>

      <nav class="home-sidebar-card home-quick-links" aria-label="快速查阅">
        <h2><%= sidebar.archive_title %></h2>
        <% (home.pathways || []).forEach((item, index) => { %>
          <a href="<%- url_for(item.url) %>">
            <span><%= String(index + 1).padStart(2, '0') %></span>
            <div><strong><%= item.title %></strong><small><%= item.desc %></small></div>
            <em aria-hidden="true">→</em>
          </a>
        <% }); %>
      </nav>

      <section class="home-sidebar-card home-batch-note">
        <p class="eyebrow"><%= sidebar.batch_eyebrow %></p>
        <h2><%= sidebar.batch_title %></h2>
        <p><%= sidebar.batch_copy %></p>
        <a class="text-link" href="<%- url_for(sidebar.batch_url) %>"><%= sidebar.batch_link %><span aria-hidden="true">→</span></a>
      </section>

      <section class="home-sidebar-card home-consult-card">
        <p class="eyebrow"><%= sidebar.consultation_eyebrow %></p>
        <h2><%= sidebar.consultation_title %></h2>
        <p><%= sidebar.consultation_copy %></p>
        <a class="button light" href="<%- url_for('/contact/') %>"><%= sidebar.consultation_link %></a>
      </section>
    </aside>
  </div>

  <section class="home-principles">
    <header class="section-heading">
      <div>
        <p class="eyebrow"><%= sections.principles.eyebrow %></p>
        <h2><%= sections.principles.title %></h2>
        <p><%= sections.principles.copy %></p>
      </div>
    </header>
    <div class="home-principle-grid">
      <% (sections.principles.items || []).forEach((item) => { %>
        <article>
          <span><%= item.number %></span>
          <h3><%= item.title %></h3>
          <p><%= item.desc %></p>
        </article>
      <% }); %>
    </div>
  </section>

  <section class="consult-band">
    <div>
      <p class="eyebrow"><%= home.contact.eyebrow %></p>
      <h2><%= home.contact.title %></h2>
      <p><%= home.contact.copy %></p>
    </div>
    <a class="button light" href="<%- url_for('/contact/') %>"><%= home.contact.button %></a>
  </section>
</div>
